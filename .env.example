# --- Kiteworks Auth ---
KITEWORKS_BASE_URL=https://securesharek.target.com
KITEWORKS_USERNAME=
KITEWORKS_PASSWORD=
KITEWORKS_CLIENT_ID=1c9f2b24-847e-5ee6-acc4-f03c8da0cfba
KITEWORKS_CLIENT_SECRET=2bLyg*oqja
# OAuth scope. Start with the wildcard; if Kiteworks rejects, fall back to explicit resources.
KITEWORKS_OAUTH_SCOPE=*/*/*
KITEWORKS_API_VERSION=15

# --- Vendor identity ---
BPD_VENDOR_ID=139440
BPD_VENDOR_TIER=BV

# --- Local storage paths (tildes are expanded) ---
BPD_DATA_DIR=~/.bpd-mcp
# The four sub-paths below default to ${BPD_DATA_DIR}/... when unset.
# BPD_RAW_DIR=
# BPD_EXTRACT_DIR=
# BPD_DB_PATH=
# BPD_TOKEN_FILE=

# --- Behavior ---
BPD_AUTO_SYNC_ON_START=false
BPD_LOG_LEVEL=INFO
BPD_HTTP_TIMEOUT=60
BPD_MAX_PARALLEL_DOWNLOADS=4
BPD_RAW_DIR_MAX_BYTES=5368709120  # 5 GiB
